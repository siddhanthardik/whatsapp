# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/whatsapp-platform?retryWrites=true&w=majority

# JWT secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Redis
REDIS_URL=redis://:password@redis-host:6379

# Meta / WhatsApp Business API
WABA_TOKEN=your_meta_whatsapp_business_api_token
WABA_PHONE_NUMBER_ID=123456789012345
WABA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# App environment
NODE_ENV=development
PORT=5000
